---
import SocialMedias from "./SocialMedias.astro";
import BinaryRain from "./BinaryRain.astro";
---

<footer
  data-binary-rain
  class="mt-auto border-t border-term-border-light dark:border-term-border transition-colors duration-300 relative overflow-hidden footer-binary-wrapper binary-rain-wrapper"
>
  <BinaryRain />
  <div
    class="h-px bg-gradient-to-r from-transparent via-accent to-transparent dark:via-accent-light relative z-10"
  >
  </div>
  <div
    class="container mx-auto flex flex-col items-center justify-center space-y-4 py-8 px-6 relative z-10"
  >
    <SocialMedias />
    <p class="text-xs font-mono text-term-gray dark:text-term-gray">
      <span class="text-accent/60 dark:text-accent-light/50">//</span>&copy;
      Kazuki Ohki 2023
    </p>
  </div>
</footer>

<style>
  .footer-binary-wrapper {
    min-height: 120px;
  }

  .binary-rain-wrapper:hover :global(.binary-rain-canvas) {
    opacity: 1;
  }
</style>
