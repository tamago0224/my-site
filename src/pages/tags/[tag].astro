---
import BlogPost from "../../components/BlogPost.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPosts, getPostsByTag, getPostTags } from "../../lib/posts";

export async function getStaticPaths() {
  const allPosts = getAllPosts();

  return getPostTags(allPosts).map((tag) => {
    return {
      params: { tag },
      props: { posts: getPostsByTag(allPosts, tag) },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout pageTitle={tag} browserTitle={`tamago tech - ${tag}`}>
  <p class="text-xs font-mono mb-6 text-term-gray dark:text-term-gray">
    <span class="text-accent dark:text-accent-light">$</span> posts --tag=<span
      class="tag-badge">{tag}</span
    >
  </p>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      posts.map((post) => (
        <BlogPost
          url={post.url}
          title={post.frontmatter.title}
          pubDate={post.frontmatter.pubDate}
          description={post.frontmatter.description}
          image={post.frontmatter.image}
          tags={post.frontmatter.tags}
        />
      ))
    }
  </div>
</BaseLayout>
