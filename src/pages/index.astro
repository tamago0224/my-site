---
import { Image } from "astro:assets";
import SkillGroup from "../components/SkillGroup.astro";
import SocialMedias from "../components/SocialMedias.astro";
import TerminalSection from "../components/TerminalSection.astro";
import profileImg from "../images/portfolio-avatar.png";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Profile";

const languages = ["Go", "Java", "JavaScript", "TypeScript", "Python"];
const frameworks = ["Spring Boot", "React"];
---

<BaseLayout pageTitle={pageTitle} browserTitle="tamago tech">
  <div class="flex flex-col items-center justify-center text-center font-mono">
    <!-- Avatar -->
    <div class="relative mb-6 animate-fade-in">
      <div
        class="p-0.5 border-2 border-accent dark:border-accent-light inline-block"
      >
        <Image
          src={profileImg}
          alt="イメージアイコン"
          width={160}
          height={160}
          class="block transition-all duration-500"
        />
      </div>
    </div>

    <SocialMedias />

    <TerminalSection
      command="skills --list"
      class="mt-10"
      style="animation-delay: 0.1s;"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <SkillGroup title="Languages" items={languages} />
        <SkillGroup title="Frameworks" items={frameworks} variant="secondary" />
      </div>
    </TerminalSection>

    <!-- Career Section -->
    <TerminalSection
      command="career --show"
      class="mt-8"
      style="animation-delay: 0.2s;"
    >
      <div class="term-card p-4">
        <p class="text-sm text-term-gray dark:text-term-gray">
          <span class="text-accent/50 dark:text-accent-light/40">//</span>Coming
          soon
        </p>
      </div>
    </TerminalSection>

    <!-- Qualification Section -->
    <TerminalSection
      command="qualification --show"
      class="mt-8"
      style="animation-delay: 0.3s;"
    >
      <div class="term-card p-4">
        <p class="text-sm text-term-gray dark:text-term-gray">
          <span class="text-accent/50 dark:text-accent-light/40">//</span>none
        </p>
      </div>
    </TerminalSection>
  </div>
</BaseLayout>
